---
import { CONTACT_EMAIL, SOCIAL_LINKS, SITE_TITLE } from '../consts';

const today = new Date();
---

<footer>
	<div class="footer-grid">
		<div>
			<p class="eyebrow">Astrophotography</p>
			<p class="brand">{SITE_TITLE}</p>
			<p class="muted">A SpaceX-inspired journal focused solely on deep-sky imaging.</p>
		</div>
		<div>
			<p class="eyebrow">Contact</p>
			<a class="footer-link" href={`mailto:${CONTACT_EMAIL}`}>
				{CONTACT_EMAIL}
			</a>
		</div>
		<div>
			<p class="eyebrow">Channels</p>
			<div class="social-links">
				{
					SOCIAL_LINKS.map((social) => (
						<a href={social.href} target="_blank" rel="noreferrer">
							{social.label}
						</a>
					))
				}
			</div>
		</div>
	</div>
	<p class="legal">&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.</p>
</footer>
<style>
	footer {
		margin-top: 2rem;
		padding: 3rem 1.6rem 3.2rem;
		background: rgb(var(--bg));
		border-top: 1px solid rgba(var(--border), 0.6);
		color: rgba(var(--muted), 0.95);
	}
	.footer-grid {
		max-width: 1160px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.6rem;
	}
	.eyebrow {
		margin: 0 0 0.4rem;
		font-size: 0.65rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: rgba(var(--muted), 0.8);
	}
	.brand {
		margin: 0;
		font-size: 1rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--text));
	}
	.muted {
		margin: 0.4rem 0 0;
		font-size: 0.92rem;
		color: rgba(var(--muted), 0.95);
	}
	.footer-link {
		color: rgb(var(--text));
		text-decoration: none;
		border-bottom: 1px solid rgba(var(--border), 0.7);
	}
	.social-links {
		display: flex;
		gap: 0.6rem;
		flex-wrap: wrap;
	}
	.social-links a {
		text-decoration: none;
		padding: 0.35rem 0.6rem;
		border: 1px solid rgba(var(--border), 0.9);
		border-radius: 0;
		font-size: 0.7rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgb(var(--text));
	}
	.legal {
		max-width: 1160px;
		margin: 2rem auto 0;
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(var(--muted), 0.7);
	}
</style>
