---
import { CONTACT_EMAIL, SOCIAL_LINKS, SITE_TITLE } from '../consts';

const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} {SITE_TITLE}</p>
	<p>
		Contact:
		<a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
	</p>
	<div class="social-links">
		{
			SOCIAL_LINKS.map((social) => (
				<a href={social.href} target="_blank" rel="noreferrer">
					{social.label}
				</a>
			))
		}
	</div>
</footer>
<style>
	footer {
		margin-top: 2rem;
		padding: 2.2rem 1rem 3rem;
		background: rgba(var(--surface), 0.8);
		border-top: 1px solid rgba(var(--border), 0.7);
		color: rgba(var(--muted), 0.95);
		text-align: center;
	}
	p {
		margin: 0.2rem 0;
	}
	a {
		color: rgb(var(--text));
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 0.7rem;
		margin-top: 0.8rem;
		flex-wrap: wrap;
	}
	.social-links a {
		text-decoration: none;
		padding: 0.35rem 0.7rem;
		border: 1px solid rgba(var(--border), 1);
		border-radius: 999px;
		color: rgb(var(--text));
	}
	.social-links a:hover {
		border-color: rgba(var(--accent), 0.6);
	}
</style>
