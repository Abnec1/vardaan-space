---
import { NAV_LINKS, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="logo" href="/">{SITE_TITLE}</a>
		<div class="internal-links">
			{
				NAV_LINKS.map((link) => (
					<HeaderLink href={link.href}>{link.label}</HeaderLink>
				))
			}
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: clamp(1.05rem, 2.6vw, 1.35rem) clamp(1rem, 4vw, 1.9rem);
		background: rgb(var(--bg));
		border-bottom: 1px solid rgba(var(--border), 0.6);
	}
	.logo {
		text-decoration: none;
		color: rgb(var(--text));
		letter-spacing: 0.12em;
		font-size: 0.98rem;
		font-family: var(--font-brand);
		font-weight: 300;
	}
	.logo:hover {
		color: rgb(var(--accent));
	}
	nav {
		display: flex;
		align-items: center;
		gap: 1rem;
		position: relative;
	}
	.internal-links {
		display: flex;
		gap: 1.8rem;
		align-items: center;
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
	}
	.internal-links a {
		margin: 0;
		font-size: 0.72rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		padding: 0.5rem 0.95rem;
		color: rgb(var(--text));
		border: 1px solid rgba(var(--border), 0.5);
		border-radius: 0;
		text-decoration: none;
		font-family: var(--font-brand);
		font-weight: 300;
		transition: border-color 160ms ease, color 160ms ease;
	}
	.internal-links a.active {
		border-color: rgba(var(--accent), 0.9);
		color: rgb(var(--accent));
	}
	@media (max-width: 720px) {
		nav {
			flex-direction: column;
			align-items: flex-start;
		}
		.internal-links {
			position: static;
			transform: none;
			gap: 0.8rem;
		}
	}
</style>
