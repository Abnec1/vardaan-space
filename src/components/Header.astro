---
import { NAV_LINKS, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="logo" href="/">{SITE_TITLE}</a>
		<div class="internal-links">
			{
				NAV_LINKS.map((link) => (
					<HeaderLink href={link.href}>{link.label}</HeaderLink>
				))
			}
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 0.95rem 1.6rem;
		background: rgb(var(--bg));
		border-bottom: 1px solid rgba(var(--border), 0.6);
	}
	.logo {
		text-decoration: none;
		color: rgb(var(--text));
		letter-spacing: 0.12em;
		font-size: 0.85rem;
	}
	.logo:hover {
		color: rgb(var(--accent));
	}
	nav {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: center;
		gap: 1rem;
	}
	.internal-links {
		display: flex;
		gap: 1.6rem;
		align-items: center;
		justify-self: center;
	}
	nav a {
		margin: 0;
		font-size: 0.65rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		padding: 0.4rem 0.8rem;
		color: rgb(var(--text));
		border: 1px solid rgba(var(--border), 0.5);
		border-radius: 0;
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-size: 0.65rem;
		transition: border-color 160ms ease, color 160ms ease;
	}
	nav a.active {
		border-color: rgba(var(--accent), 0.9);
		color: rgb(var(--accent));
	}
	@media (max-width: 720px) {
		nav {
			grid-template-columns: 1fr;
			align-items: flex-start;
		}
		.internal-links {
			justify-self: flex-start;
			gap: 0.8rem;
		}
	}
</style>
