---
import { NAV_LINKS, SITE_TAGLINE, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="brand">
			<p class="eyebrow">Night Sky Journal</p>
			<h2><a href="/">{SITE_TITLE}</a></h2>
			<p class="tagline">{SITE_TAGLINE}</p>
		</div>
		<div class="internal-links">
			{
				NAV_LINKS.map((link) => (
					<HeaderLink href={link.href}>{link.label}</HeaderLink>
				))
			}
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 0.85rem 1rem;
		background: rgba(var(--surface), 78%);
		backdrop-filter: blur(16px);
		border-bottom: 1px solid rgba(var(--border), 0.5);
	}
	.brand {
		display: grid;
		gap: 0.2rem;
	}
	.eyebrow {
		margin: 0;
		font-size: 0.72rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(var(--muted), 0.9);
	}
	h2 {
		margin: 0;
		font-size: 1.02rem;
		letter-spacing: 0.01em;
	}
	.tagline {
		margin: 0;
		font-size: 0.78rem;
		color: rgba(var(--muted), 0.92);
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--text));
	}
	nav {
		display: flex;
		align-items: center;
		gap: 1rem;
		justify-content: space-between;
	}
	.internal-links {
		display: flex;
		gap: 0.4rem;
		align-items: center;
		flex-wrap: wrap;
	}
	nav a {
		padding: 0.5rem 0.8rem;
		color: rgb(var(--text));
		border: 1px solid transparent;
		border-radius: 999px;
		text-decoration: none;
		transition: border-color 160ms ease, background-color 160ms ease;
	}
	nav a.active {
		border-color: rgba(var(--accent), 0.45);
		background: rgba(var(--accent), 0.14);
	}
	@media (max-width: 720px) {
		nav {
			flex-direction: column;
			align-items: flex-start;
		}
		.tagline {
			display: none;
		}
	}
</style>
