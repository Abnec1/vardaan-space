---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const gallery = (await getCollection('blog'))
	.filter((post) => post.data.heroImage)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tileSizes = ['tile-s', 'tile-m', 'tile-l', 'tile-m'];
const tileShapes = ['shape-a', 'shape-b', 'shape-c', 'shape-d', 'shape-e'];

const getTileClass = (id, index) => {
	const seed = [...id].reduce((total, char) => total + char.charCodeAt(0), 0) + index * 13;
	const size = tileSizes[seed % tileSizes.length];
	const shape = tileShapes[(seed + index) % tileShapes.length];
	return `${size} ${shape}`;
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Gallery | ${SITE_TITLE}`}
			description="Astrophotography images drawn from the full blog archive."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<p class="chip">Gallery</p>
				<h1>Astrophotography captures</h1>
			</section>

			<ul class="gallery-list">
				{
					gallery.map((entry, index) => (
						<li class={`gallery-row ${getTileClass(entry.id, index)}`}>
							<a href={`/blog/${entry.id}/`} class="row-link">
								<div class="row-media">
									<Image src={entry.data.heroImage} alt={entry.data.title} width={1680} height={1120} />
								</div>
								<span class="sr-only">{entry.data.title}</span>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		padding: 0 0 2.5rem;
		border-bottom: 1px solid rgba(var(--border), 0.6);
		margin-bottom: 0;
	}
	.gallery-list {
		list-style: none;
		padding: 0;
		margin: 2rem 0 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: clamp(0.8rem, 2.4vw, 1.6rem);
		grid-auto-rows: 120px;
		grid-auto-flow: dense;
	}
	.gallery-row {
		position: relative;
		overflow: hidden;
		background: rgba(var(--surface), 0.9);
		border: 1px solid rgba(var(--border), 0.6);
		border-radius: 22px;
	}
	.row-link {
		display: block;
		height: 100%;
		text-decoration: none;
		color: inherit;
	}
	.row-media {
		background: rgb(var(--bg));
		height: 100%;
	}
	.row-media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.tile-s {
		grid-column: span 1;
		grid-row: span 2;
	}
	.tile-m {
		grid-column: span 2;
		grid-row: span 3;
	}
	.tile-l {
		grid-column: span 2;
		grid-row: span 4;
	}
	@supports (clip-path: polygon(0 0, 100% 0, 100% 100%)) {
		.shape-a {
			clip-path: polygon(0 6%, 92% 0, 100% 24%, 96% 100%, 8% 100%, 0 78%);
		}
		.shape-b {
			clip-path: polygon(6% 0, 100% 0, 100% 92%, 82% 100%, 0 100%, 0 12%);
		}
		.shape-c {
			clip-path: polygon(0 0, 96% 4%, 100% 28%, 94% 100%, 12% 96%, 0 72%);
		}
		.shape-d {
			clip-path: polygon(4% 0, 100% 6%, 96% 100%, 0 94%, 0 18%);
		}
		.shape-e {
			clip-path: polygon(0 10%, 86% 0, 100% 18%, 96% 100%, 12% 94%, 0 76%);
		}
	}
	@media (max-width: 960px) {
		.gallery-list {
			grid-auto-rows: 110px;
		}
		.tile-m,
		.tile-l {
			grid-column: span 1;
			grid-row: span 2;
		}
	}
	@media (max-width: 600px) {
		.gallery-list {
			grid-auto-rows: 100px;
		}
	}
</style>
