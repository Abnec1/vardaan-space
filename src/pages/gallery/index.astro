---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const gallery = (await getCollection('gallery')).sort(
	(a, b) => b.data.captureDate.valueOf() - a.data.captureDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Gallery | ${SITE_TITLE}`}
			description="Astrophotography captures with short observing notes and setup details."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<p class="chip">Gallery</p>
				<h1>Astrophotography captures</h1>
				<p>
					A SpaceX-inspired presentation of deep-sky frames, each paired with target notes and the capture
					configuration behind it.
				</p>
			</section>

			<ul class="gallery-list">
				{
					gallery.map((entry) => (
						<li class="gallery-row">
							<a href={`/gallery/${entry.id}/`} class="row-link">
								<div class="row-media">
									<Image src={entry.data.image} alt={entry.data.title} width={1680} height={1120} />
								</div>
								<div class="row-copy">
									<p class="eyebrow">{entry.data.captureDate.toLocaleDateString('en-US')}</p>
									<h2>{entry.data.title}</h2>
									<p class="description">{entry.data.description}</p>
									<p class="meta">
										{entry.data.location && <span>{entry.data.location}</span>}
										{entry.data.equipment && <span>{entry.data.equipment}</span>}
									</p>
									<span class="learn">Learn more →</span>
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		padding: 0 0 2.5rem;
		border-bottom: 1px solid rgba(var(--border), 0.6);
		margin-bottom: 0;
	}
	.gallery-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0;
	}
	.gallery-row {
		border-bottom: 1px solid rgba(var(--border), 0.6);
	}
	.row-link {
		display: grid;
		grid-template-columns: minmax(0, 1.65fr) minmax(0, 0.95fr);
		min-height: 72vh;
		width: 100vw;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
		text-decoration: none;
		color: inherit;
	}
	.row-media {
		background: rgb(var(--bg));
	}
	.row-media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.row-copy {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: clamp(2rem, 5vw, 4.5rem);
		background: rgba(var(--surface), 0.96);
	}
	.eyebrow {
		margin: 0 0 0.8rem;
		font-size: 0.65rem;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: rgba(var(--muted), 0.85);
	}
	.description {
		max-width: 42ch;
	}
	.meta {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		margin: 0;
		font-size: 0.9rem;
		color: rgba(var(--muted), 0.95);
	}
	.learn {
		margin-top: 1.2rem;
		font-size: 0.7rem;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: rgb(var(--text));
		border-bottom: 1px solid rgba(var(--border), 0.8);
		padding-bottom: 0.3rem;
		width: fit-content;
	}
	@media (max-width: 960px) {
		.row-link {
			grid-template-columns: 1fr;
			min-height: auto;
		}
		.row-media {
			min-height: 52vh;
		}
	}
</style>
