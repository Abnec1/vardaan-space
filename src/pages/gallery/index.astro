---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const gallery = (await getCollection('gallery')).sort(
	(a, b) => b.data.captureDate.valueOf() - a.data.captureDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Gallery | ${SITE_TITLE}`}
			description="Astrophotography images drawn from the full blog archive."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<p class="chip">Gallery</p>
				<h1>Astrophotography captures</h1>
			</section>

			<ul class="gallery-list full-bleed">
				{
					gallery.map((entry) => (
						<li class="gallery-row">
							<a href={`/gallery/${entry.id}/`} class="row-link">
								<div class="row-media">
									<Image src={entry.data.image} alt={entry.data.title} width={1680} height={1120} />
								</div>
								<span class="sr-only">{entry.data.title}</span>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		padding: 0 0 2.5rem;
		border-bottom: 1px solid rgba(var(--border), 0.6);
		margin-bottom: 0;
	}
	.gallery-list {
		list-style: none;
		padding: 0;
		margin: 2.2rem 0 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: clamp(0.7rem, 1.8vw, 1.2rem);
		grid-auto-flow: row;
	}
	.gallery-row {
		position: relative;
		overflow: hidden;
		aspect-ratio: 4 / 3;
		background: rgba(var(--surface), 0.9);
		border: 1px solid rgba(var(--border), 0.6);
		border-radius: 0;
		transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
		will-change: transform;
		z-index: 0;
	}
	.gallery-row:hover {
		transform: translate(-6px, -6px) rotate(-0.4deg);
		box-shadow: var(--box-shadow);
		border-color: rgba(var(--accent), 0.5);
		z-index: 2;
	}
	.row-link {
		display: block;
		height: 100%;
		text-decoration: none;
		color: inherit;
	}
	.row-media {
		background: rgb(var(--bg));
		height: 100%;
	}
	.row-media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	@media (prefers-reduced-motion: reduce) {
		.gallery-row {
			transition: none;
		}
		.gallery-row:hover {
			transform: none;
		}
	}
</style>
