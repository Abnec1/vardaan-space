---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const gallery = (await getCollection('gallery')).sort(
	(a, b) => b.data.captureDate.valueOf() - a.data.captureDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Gallery | ${SITE_TITLE}`}
			description="Astrophotography captures with short observing notes and setup details."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro glass-card">
				<p class="chip">Astrophotography Gallery</p>
				<h1>Night sky captures</h1>
				<p>
					Every frame here is paired with a concise note: what I saw, where I shot from, and the setup I
					used.
				</p>
			</section>

			<ul class="gallery-list">
				{
					gallery.map((entry) => (
						<li class="glass-card card">
							<a href={`/gallery/${entry.id}/`} class="card-link">
								<div class="image-wrap">
									<Image src={entry.data.image} alt={entry.data.title} width={1080} height={720} />
								</div>
								<div class="details">
									<p class="chip">{entry.data.captureDate.toLocaleDateString('en-US')}</p>
									<h2>{entry.data.title}</h2>
									<p>{entry.data.description}</p>
									<p class="meta">
										{entry.data.location && <span>{entry.data.location}</span>}
										{entry.data.equipment && <span>{entry.data.equipment}</span>}
									</p>
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		padding: 1.1rem;
		margin-bottom: 1rem;
	}
	.gallery-list {
		list-style: none;
		padding: 0;
		display: grid;
		gap: 1rem;
	}
	.card {
		padding: 0.8rem;
	}
	.card-link {
		display: grid;
		grid-template-columns: 1.45fr 1fr;
		gap: 0.95rem;
		text-decoration: none;
		color: inherit;
	}
	.image-wrap img {
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
	}
	.details h2 {
		margin-top: 0.6rem;
		margin-bottom: 0.4rem;
		font-size: 1.4rem;
	}
	.meta {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		margin: 0;
		font-size: 0.92rem;
		color: rgba(var(--muted), 0.95);
	}
	@media (max-width: 900px) {
		.card-link {
			grid-template-columns: 1fr;
		}
	}
</style>
