---
import { Image } from 'astro:assets';
import AboutHeroImage from '../assets/telescope.png';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { CONTACT_EMAIL, CONTACT_LOCATION, SOCIAL_LINKS } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="About"
			description="About and contact details for Vardaan's astronomy and astrophotography blog."
			image={AboutHeroImage}
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="about glass-card">
				<div class="portrait">
					<Image src={AboutHeroImage} alt="Night sky setup and horizon" width={920} height={1120} />
				</div>
				<div class="copy">
					<p class="chip">About</p>
					<h1>About the photographer</h1>
					<p>
						Hey! I'm an amateur astronomer and astrophotographer, who's been told constantly to share his findings and techniques, and so here we are. I hope you enjoy the content and find it useful.

					</p>
					<p>
                        This site records each session or project, and the techniques used to capture and process the images. I also share my thoughts on equipment, workflow, and other topics related to astrophotography. I photograph all kinds of objects, but am limited by the seeing conditions and light pollution in my area, so I mainly photograph bright objects like the moon and planets.
					</p>
					<p>
						If you're interested in any of my techniques, gear, workflow, images, etc., there's an e-mail below. Clear Skies.					

					</p>
				</div>
			</section>

			<section class="details glass-card">
				<div>
					<p class="chip">Equipment</p>
					<h2>The Telescope</h2>
					<ul>
						<li>Celestron C8 Schmidt Cassegrain, about 10 years old.</li>
						<li>Celestron AVX Mount, 10 years old, controlled with CPWI and NINA.</li>
						<li>Nikon D32000 for deep-sky and lunar imaging, and the NexImage 10 for planetary imaging. Hoping to upgrade to a 585MC Air in the future.</li>
					</ul>
				</div>
				<div>
					<p class="chip">Workflow</p>
					<h2>Imaging Workflow</h2>
					<ul>
						<li>Plan the target window, framing, and exposure length per session, also as per viewing conditions since I live in a very humid place.</li>
						<li>Capture frames, say lunar, seperate and align using PIPP, stack using AutoStakkert.</li>
						<li>Finally, wavelet sharpen in Registax, and boost contrast in Photoshop.</li>
					</ul>
				</div>
			</section>

			<section class="contact glass-card">
				<p class="chip">Contact</p>
				<h2>Connect</h2>
				<p>
					Email:
					<a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
				</p>
				<p>Location: {CONTACT_LOCATION}</p>
				<div class="social-list">
					{
						SOCIAL_LINKS.map((social) => (
							<a href={social.href} target="_blank" rel="noreferrer">
								{social.label}
							</a>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about {
		display: grid;
		grid-template-columns: minmax(220px, 0.8fr) 1.4fr;
		gap: 1rem;
		padding: 1.1rem;
	}
	.portrait img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.copy {
		padding: 0.6rem;
	}
	.details {
		margin-top: 1rem;
		padding: 1.2rem 1.3rem;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1.4rem;
	}
	.details ul {
		margin: 0.8rem 0 0;
		padding-left: 1.1rem;
		color: rgba(var(--muted), 0.95);
	}
	.details li {
		margin-bottom: 0.6rem;
	}
	.contact {
		margin-top: 1rem;
		padding: 1.2rem 1.3rem;
	}
	.social-list {
		display: flex;
		gap: 0.6rem;
		flex-wrap: wrap;
	}
	.social-list a {
		padding: 0.35rem 0.6rem;
		border: 1px solid rgba(var(--border), 0.9);
		border-radius: 0;
		text-decoration: none;
		color: rgb(var(--text));
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.7rem;
	}
	@media (max-width: 860px) {
		.about {
			grid-template-columns: 1fr;
		}
	}
</style>
