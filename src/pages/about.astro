---
import { Image } from 'astro:assets';
import AboutHeroImage from '../assets/blog-placeholder-about.jpg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { CONTACT_EMAIL, CONTACT_LOCATION, SITE_TITLE, SOCIAL_LINKS } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`About | ${SITE_TITLE}`}
			description="About and contact details for Vardaan's astronomy and astrophotography blog."
			image={AboutHeroImage}
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="about glass-card">
				<div class="portrait">
					<Image src={AboutHeroImage} alt="Night sky setup and horizon" width={920} height={1120} />
				</div>
				<div class="copy">
					<p class="chip">Mission Brief</p>
					<h1>About the observer</h1>
					<p>
						I'm an amateur astronomer and astrophotographer focused on precise capture workflows, deep-sky
						imaging, and disciplined post-processing.
					</p>
					<p>
						This site records each session in a mission-log format: targets, instrument settings, and what
						the sky revealed.
					</p>
					<p>
						If you're building a serious observing workflow, reach out to compare techniques or trade
						processing notes.
					</p>
				</div>
			</section>

			<section class="contact glass-card">
				<p class="chip">Operations</p>
				<h2>Coordination</h2>
				<p>
					Email:
					<a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
				</p>
				<p>Location: {CONTACT_LOCATION}</p>
				<div class="social-list">
					{
						SOCIAL_LINKS.map((social) => (
							<a href={social.href} target="_blank" rel="noreferrer">
								{social.label}
							</a>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about {
		display: grid;
		grid-template-columns: minmax(220px, 0.8fr) 1.4fr;
		gap: 1rem;
		padding: 1.1rem;
	}
	.portrait img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.copy {
		padding: 0.6rem;
	}
	.contact {
		margin-top: 1rem;
		padding: 1.2rem 1.3rem;
	}
	.social-list {
		display: flex;
		gap: 0.6rem;
		flex-wrap: wrap;
	}
	.social-list a {
		padding: 0.35rem 0.6rem;
		border: 1px solid rgba(var(--border), 0.9);
		border-radius: 0;
		text-decoration: none;
		color: rgb(var(--text));
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.7rem;
	}
	@media (max-width: 860px) {
		.about {
			grid-template-columns: 1fr;
		}
	}
</style>
