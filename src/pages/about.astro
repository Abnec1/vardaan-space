---
import { Image } from 'astro:assets';
import AboutHeroImage from '../assets/blog-placeholder-about.jpg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { CONTACT_EMAIL, CONTACT_LOCATION, SITE_TITLE, SOCIAL_LINKS } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`About | ${SITE_TITLE}`}
			description="About and contact details for Vardaan's astronomy and astrophotography blog."
			image={AboutHeroImage}
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="about glass-card">
				<div class="portrait">
					<Image src={AboutHeroImage} alt="Night sky setup and horizon" width={920} height={1120} />
				</div>
				<div class="copy">
					<p class="chip">About me</p>
					<h1>Hi, I'm Vardaan.</h1>
					<p>
						I'm an amateur astronomer and astrophotographer who loves spending clear nights tracking down
						deep-sky objects, planetary detail, and wide-field star patterns.
					</p>
					<p>
						This site is where I document each observing session: what worked, what failed, and what the
						sky taught me.
					</p>
					<p>
						If you're also building your sky workflow, feel free to reach out. I enjoy collaborating with
						other observers and sharing processing ideas.
					</p>
				</div>
			</section>

			<section id="contact" class="contact glass-card">
				<p class="chip">Contact</p>
				<h2>Let's connect</h2>
				<p>
					Email:
					<a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
				</p>
				<p>Location: {CONTACT_LOCATION}</p>
				<div class="social-list">
					{
						SOCIAL_LINKS.map((social) => (
							<a href={social.href} target="_blank" rel="noreferrer">
								{social.label}
							</a>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about {
		display: grid;
		grid-template-columns: minmax(210px, 0.8fr) 1.3fr;
		gap: 1rem;
		padding: 0.9rem;
	}
	.portrait img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.copy {
		padding: 0.4rem;
	}
	.contact {
		margin-top: 1rem;
		padding: 1rem 1.1rem;
	}
	.social-list {
		display: flex;
		gap: 0.6rem;
		flex-wrap: wrap;
	}
	.social-list a {
		padding: 0.35rem 0.75rem;
		border: 1px solid rgba(var(--border), 1);
		border-radius: 999px;
		text-decoration: none;
		color: rgb(var(--text));
	}
	@media (max-width: 860px) {
		.about {
			grid-template-columns: 1fr;
		}
	}
</style>
