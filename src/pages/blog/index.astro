---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION } from '../../consts';
import { getPrimaryBlogImage, getReadingTime } from '../../lib/blog';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Blog" description={SITE_DESCRIPTION} />
		<style>
			.intro {
				padding: 1.3rem;
				margin-bottom: 1.2rem;
			}
			ul {
				display: grid;
				gap: 1.1rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			li {
				padding: 0.9rem;
			}
			li a {
				display: grid;
				grid-template-columns: 1.35fr 1fr;
				gap: 0.95rem;
				text-decoration: none;
				color: inherit;
			}
			.media img {
				width: 100%;
				aspect-ratio: 16 / 10;
				object-fit: cover;
			}
			.copy h2 {
				margin-top: 0.6rem;
				margin-bottom: 0.4rem;
				font-family: var(--font-heading);
				font-weight: 700;
			}
			.description {
				margin-bottom: 0.8rem;
				font-family: var(--font-body);
				font-weight: 500;
			}
			.meta {
				margin: 0;
				color: rgba(var(--muted), 0.95);
				font-size: 0.9rem;
			}
			@media (max-width: 720px) {
				li a {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro glass-card">
				<p class="chip">Blog</p>
				<h1>Astrophotography notes</h1>
				<p>Session write-ups, processing choices, and capture lessons from each night.</p>
			</section>
			<section>
				<ul>
					{
						posts.map((post) => (
							(() => {
								const image = getPrimaryBlogImage(post.data);
								return (
									<li class="glass-card">
										<a href={`/blog/${post.id}/`}>
											<div class="media">{image && <Image width={920} height={560} src={image} alt={post.data.title} />}</div>
											<div class="copy">
												<p class="chip">
													<FormattedDate date={post.data.pubDate} />
												</p>
												<h2>{post.data.title}</h2>
												<p class="description">{post.data.description}</p>
												<p class="meta">
													<span>{getReadingTime(post.body)}</span>
													<span>Read post →</span>
												</p>
											</div>
										</a>
									</li>
								);
							})()
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
