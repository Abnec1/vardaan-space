---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { CONTACT_EMAIL, CONTACT_LOCATION, SOCIAL_LINKS } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Contact"
			description="Contact mission operations for collaboration, feedback, or astronomy discussions."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="contact-hero glass-card">
				<div>
					<p class="chip">Contact</p>
					<h1>Get in touch</h1>
					<p>
						Use the channels below for collaboration, observing questions, or processing workflow
						feedback.
					</p>
					<div class="contact-details">
						<div>
							<p class="label">Primary Link</p>
							<a class="value" href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
						</div>
						<div>
							<p class="label">Location</p>
							<p class="value">{CONTACT_LOCATION}</p>
						</div>
					</div>
				</div>
				<div class="contact-card">
					<p class="chip">Direct Links</p>
					<div class="social-list">
						{
							SOCIAL_LINKS.map((social) => (
								<a href={social.href} target="_blank" rel="noreferrer">
									{social.label}
								</a>
							))
						}
					</div>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	.contact-hero {
		padding: 1.4rem;
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
		gap: 1.6rem;
	}
	.contact-details {
		margin-top: 1.4rem;
		display: grid;
		gap: 1rem;
	}
	.label {
		margin: 0 0 0.2rem;
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: rgba(var(--muted), 0.85);
	}
	.value {
		margin: 0;
		color: rgb(var(--text));
	}
	.contact-card {
		padding: 1rem;
		border: 1px solid rgba(var(--border), 0.7);
		border-radius: 0;
		background: rgba(var(--surface-2), 0.85);
	}
	.social-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: 0.8rem;
	}
	.social-list a {
		text-decoration: none;
		padding: 0.35rem 0.6rem;
		border: 1px solid rgba(var(--border), 0.9);
		border-radius: 0;
		font-size: 0.7rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgb(var(--text));
	}
	@media (max-width: 900px) {
		.contact-hero {
			grid-template-columns: 1fr;
		}
	}
</style>
