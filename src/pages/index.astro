---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';

const featuredGallery = (await getCollection('gallery'))
	.sort((a, b) => b.data.captureDate.valueOf() - a.data.captureDate.valueOf())
	.slice(0, 3);

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero glass-card">
				<div class="hero-main">
					<p class="chip">Mission Control</p>
					<h1>{SITE_TITLE}</h1>
					<p>
						An interstellar-themed astronomy log focused on precision capture data, dark-sky processing,
						and mission-grade observing notes.
					</p>
					<div class="cta-row">
						<a class="cta primary" href="/gallery">Explore Gallery</a>
						<a class="cta" href="/blog">Read Blog</a>
						<a class="cta" href="/contact">Contact Ops</a>
					</div>
				</div>
				<div class="hero-panel">
					<p class="chip">Telemetry Snapshot</p>
					<div class="telemetry-grid">
						<div>
							<p class="label">Current Mission</p>
							<p class="value">Deep-Sky Survey</p>
						</div>
						<div>
							<p class="label">Capture Window</p>
							<p class="value">New Moon Cycle</p>
						</div>
						<div>
							<p class="label">Primary Payload</p>
							<p class="value">Wide-Field Imaging</p>
						</div>
						<div>
							<p class="label">Processing Stack</p>
							<p class="value">Calibration · Stacking · De-noise</p>
						</div>
					</div>
				</div>
			</section>

			<section class="section">
				<div class="section-head">
					<h2>Featured captures</h2>
					<a href="/gallery">View full gallery</a>
				</div>
				<ul class="photo-list">
					{
						featuredGallery.map((entry) => (
							<li class="glass-card photo-item">
								<a class="photo-link" href={`/gallery/${entry.id}/`}>
									<div class="media">
										<Image src={entry.data.image} alt={entry.data.title} width={1080} height={720} />
									</div>
									<div class="copy">
										<p class="chip">{entry.data.captureDate.toLocaleDateString('en-US')}</p>
										<h3>{entry.data.title}</h3>
										<p>{entry.data.description}</p>
										<p class="meta">
											{entry.data.location && <span>{entry.data.location}</span>}
											{entry.data.equipment && <span>{entry.data.equipment}</span>}
										</p>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>

			<section class="section">
				<div class="section-head">
					<h2>Recent astronomy notes</h2>
					<a href="/blog">Browse all posts</a>
				</div>
				<ul class="blog-list">
					{
						recentPosts.map((post) => (
							<li class="glass-card post-item">
								<a href={`/blog/${post.id}/`}>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
									<p class="meta-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: clamp(1.3rem, 3vw, 2.2rem);
		margin-bottom: 1.4rem;
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.7fr);
		gap: 1.4rem;
	}
	.hero h1 {
		margin-top: 0.7rem;
		margin-bottom: 0.55rem;
	}
	.hero p {
		max-width: 60ch;
	}
	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 1.2rem;
	}
	.cta {
		padding: 0.6rem 1rem;
		border-radius: 4px;
		border: 1px solid rgba(var(--border), 0.8);
		text-decoration: none;
		color: rgb(var(--text));
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.7rem;
	}
	.cta.primary {
		border-color: rgba(var(--accent), 0.9);
		background: rgba(var(--accent), 0.2);
		color: rgb(var(--text));
	}
	.hero-panel {
		border: 1px solid rgba(var(--border), 0.7);
		border-radius: 4px;
		padding: 1rem;
		background: rgba(var(--surface-2), 0.8);
	}
	.telemetry-grid {
		margin-top: 0.8rem;
		display: grid;
		gap: 0.9rem;
	}
	.label {
		margin: 0 0 0.25rem;
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: rgba(var(--muted), 0.85);
	}
	.value {
		margin: 0;
		font-size: 0.95rem;
		color: rgb(var(--text));
	}
	.section {
		margin: 1.5rem 0;
	}
	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
	}
	.photo-list,
	.blog-list {
		list-style: none;
		padding: 0;
		margin: 0.7rem 0 0;
		display: grid;
		gap: 1rem;
	}
	.photo-item {
		padding: 0.8rem;
	}
	.photo-link {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 0.9rem;
		text-decoration: none;
	}
	.media img {
		width: 100%;
		object-fit: cover;
		aspect-ratio: 16 / 10;
	}
	.copy h3 {
		margin-top: 0.55rem;
		margin-bottom: 0.35rem;
	}
	.meta {
		display: flex;
		gap: 0.45rem;
		flex-wrap: wrap;
		margin: 0;
		color: rgba(var(--muted), 0.95);
		font-size: 0.92rem;
	}
	.post-item {
		padding: 0.95rem 1rem;
	}
	.post-item a {
		text-decoration: none;
		color: inherit;
	}
	.meta-date {
		margin: 0.4rem 0 0;
		color: rgba(var(--muted), 0.95);
	}
	@media (max-width: 960px) {
		.hero {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 860px) {
		.photo-link {
			grid-template-columns: 1fr;
		}
	}
</style>
