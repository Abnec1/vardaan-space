---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import jwstPillarImage from '../assets/jwst-pillar.jpg';
import jwstDeepFieldImage from '../assets/jwst-deep-field.jpg';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="chip">Astrophotography Blog</p>
				<h1>{SITE_TITLE}</h1>
				<p>
					An amateur astronomer's astrophotography journal focused entirely on deep-sky captures,
					equipment choices, and processing notes.
				</p>
				<div class="cta-row">
					<a class="cta primary" href="/blog">Read Blog</a>
					<a class="cta" href="/gallery">View Gallery</a>
					<a class="cta" href="/contact">Contact</a>
				</div>
			</section>

			<section class="split-panels full-bleed">
				<a
					class="split-panel"
					href="/blog"
					style={`--panel-image: url(${jwstPillarImage.src}); --panel-position: 50% 35%;`}
				>
					<span class="panel-button">Blog →</span>
				</a>
				<a
					class="split-panel"
					href="/gallery"
					style={`--panel-image: url(${jwstDeepFieldImage.src}); --panel-position: 50% 45%;`}
				>
					<span class="panel-button">Gallery →</span>
				</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: clamp(1.2rem, 2.6vw, 2.2rem) 0;
		margin-bottom: 1.6rem;
		border-bottom: 1px solid rgba(var(--border), 0.6);
	}
	.hero h1 {
		margin-top: 0.7rem;
		margin-bottom: 0.55rem;
	}
	.hero p {
		max-width: 60ch;
	}
	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 1.2rem;
		margin-top: 1.1rem;
	}
	.cta {
		padding: 0.2rem 0;
		border-radius: 0;
		border: none;
		text-decoration: none;
		color: rgba(var(--text), 0.92);
		text-transform: uppercase;
		letter-spacing: 0.26em;
		font-size: 0.66rem;
		border-bottom: 1px solid transparent;
		transition: color 160ms ease, border-color 160ms ease;
	}
	.cta.primary {
		border-color: transparent;
		background: transparent;
		color: rgba(var(--text), 0.92);
	}
	.cta:hover {
		color: rgb(var(--accent));
		border-color: rgba(var(--accent), 0.7);
	}
	.split-panels {
		margin-top: 2rem;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		border-top: 1px solid rgba(var(--border), 0.6);
		border-bottom: 1px solid rgba(var(--border), 0.6);
	}
	.split-panel {
		position: relative;
		min-height: clamp(260px, 38vh, 420px);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: clamp(1.6rem, 4vw, 3rem);
		text-decoration: none;
		color: rgb(var(--text));
		background-image:
			linear-gradient(
				180deg,
				rgba(0, 0, 0, 0.2) 0%,
				rgba(0, 0, 0, 0.55) 65%,
				rgba(0, 0, 0, 0.82) 100%
			),
			var(--panel-image);
		background-size: cover;
		background-position: var(--panel-position, center);
		transition: transform 220ms ease, box-shadow 220ms ease;
	}
	.split-panel + .split-panel {
		border-left: 1px solid rgba(var(--border), 0.6);
	}
	.split-panel:hover {
		transform: translateY(-4px);
		box-shadow: var(--box-shadow);
	}
	.panel-button {
		display: inline-block;
		font-size: 0.68rem;
		letter-spacing: 0.32em;
		text-transform: uppercase;
		color: rgba(var(--text), 0.9);
		border: none;
		padding: 0.2rem 0;
		background: transparent;
		border-bottom: 1px solid rgba(var(--text), 0.35);
		transition: border-color 200ms ease, color 200ms ease;
	}
	.split-panel:hover .panel-button {
		border-color: rgba(var(--accent), 0.7);
		color: rgb(var(--accent-strong));
	}
	@media (max-width: 960px) {
		.split-panels {
			grid-template-columns: 1fr;
		}
		.split-panel + .split-panel {
			border-left: none;
			border-top: 1px solid rgba(var(--border), 0.6);
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.split-panel {
			transition: none;
		}
		.split-panel:hover {
			transform: none;
			box-shadow: none;
		}
		.panel-button {
			transition: none;
		}
	}
</style>
