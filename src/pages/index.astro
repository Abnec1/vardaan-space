---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';

const featuredGallery = (await getCollection('gallery'))
	.sort((a, b) => b.data.captureDate.valueOf() - a.data.captureDate.valueOf())
	.slice(0, 3);

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="chip">Astrophotography Blog</p>
				<h1>{SITE_TITLE}</h1>
				<p>
					A SpaceX-inspired astrophotography journal focused entirely on deep-sky captures, equipment
					choices, and processing notes.
				</p>
				<div class="cta-row">
					<a class="cta primary" href="/blog">Read Blog</a>
					<a class="cta" href="/gallery">View Gallery</a>
					<a class="cta" href="/contact">Contact</a>
				</div>
			</section>

			<section class="section">
				<div class="section-head">
					<h2>Featured captures</h2>
					<a href="/gallery">View full gallery</a>
				</div>
				<ul class="featured-list">
					{
						featuredGallery.map((entry) => (
							<li class="featured-row">
								<a class="featured-link" href={`/gallery/${entry.id}/`}>
									<div class="featured-media">
										<Image src={entry.data.image} alt={entry.data.title} width={1680} height={1120} />
									</div>
									<div class="featured-copy">
										<p class="eyebrow">{entry.data.captureDate.toLocaleDateString('en-US')}</p>
										<h3>{entry.data.title}</h3>
										<p class="description">{entry.data.description}</p>
										<p class="meta">
											{entry.data.location && <span>{entry.data.location}</span>}
											{entry.data.equipment && <span>{entry.data.equipment}</span>}
										</p>
										<span class="learn">Learn more →</span>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>

			<section class="section">
				<div class="section-head">
					<h2>Recent astronomy notes</h2>
					<a href="/blog">Browse all posts</a>
				</div>
				<ul class="blog-list">
					{
						recentPosts.map((post) => (
							<li class="glass-card post-item">
								<a href={`/blog/${post.id}/`}>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
									<p class="meta-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: clamp(1.4rem, 3vw, 2.6rem) 0;
		margin-bottom: 1.4rem;
		border-bottom: 1px solid rgba(var(--border), 0.6);
	}
	.hero h1 {
		margin-top: 0.7rem;
		margin-bottom: 0.55rem;
	}
	.hero p {
		max-width: 60ch;
	}
	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 1.2rem;
	}
	.cta {
		padding: 0.55rem 1rem;
		border-radius: 0;
		border: 1px solid rgba(var(--border), 0.8);
		text-decoration: none;
		color: rgb(var(--text));
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.7rem;
	}
	.cta.primary {
		border-color: rgba(var(--accent), 0.9);
		background: rgba(var(--accent), 0.15);
		color: rgb(var(--text));
	}
	.section {
		margin: 1.5rem 0;
	}
	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
	}
	.featured-list,
	.blog-list {
		list-style: none;
		padding: 0;
		margin: 1.2rem 0 0;
		display: grid;
		gap: 0;
	}
	.featured-row {
		border-top: 1px solid rgba(var(--border), 0.6);
	}
	.featured-row:last-child {
		border-bottom: 1px solid rgba(var(--border), 0.6);
	}
	.featured-link {
		display: grid;
		grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
		min-height: 64vh;
		width: 100vw;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
		text-decoration: none;
		color: inherit;
	}
	.featured-media {
		background: rgb(var(--bg));
	}
	.featured-media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.featured-copy {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: clamp(2rem, 5vw, 4rem);
		background: rgba(var(--surface), 0.96);
	}
	.eyebrow {
		margin: 0 0 0.8rem;
		font-size: 0.65rem;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: rgba(var(--muted), 0.85);
	}
	.description {
		max-width: 42ch;
		font-family: var(--font-body);
		font-weight: 500;
	}
	.meta {
		display: flex;
		gap: 0.45rem;
		flex-wrap: wrap;
		margin: 0;
		color: rgba(var(--muted), 0.95);
		font-size: 0.92rem;
	}
	.learn {
		margin-top: 1.1rem;
		font-size: 0.7rem;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: rgb(var(--text));
		border-bottom: 1px solid rgba(var(--border), 0.8);
		padding-bottom: 0.3rem;
		width: fit-content;
	}
	.post-item {
		padding: 0.95rem 1rem;
	}
	.post-item h3 {
		font-family: var(--font-heading);
		font-weight: 700;
	}
	.post-item a {
		text-decoration: none;
		color: inherit;
	}
	.meta-date {
		margin: 0.4rem 0 0;
		color: rgba(var(--muted), 0.95);
	}
	@media (max-width: 960px) {
		.featured-link {
			grid-template-columns: 1fr;
			min-height: auto;
		}
		.featured-media {
			min-height: 52vh;
		}
	}
</style>
