---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import apodImage from '../assets/apod.png';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="chip">Astrophotography Blog</p>
				<h1>{SITE_TITLE}</h1>
				<p>
					An amateur astronomer's astrophotography journal focused entirely on deep-sky captures,
					equipment choices, and processing notes.
				</p>
				<div class="cta-row">
					<a class="cta primary" href="/blog">Read Blog</a>
					<a class="cta" href="/gallery">View Gallery</a>
					<a class="cta" href="/contact">Contact</a>
				</div>
			</section>

			<section class="split-panels full-bleed">
				<a
					class="split-panel"
					href="/blog"
					style={`--panel-image: url(${apodImage.src}); --panel-position: 22% 30%;`}
				>
					<div class="panel-inner">
						<p class="chip">Blog</p>
						<h2>Observation log</h2>
						<p>Session write-ups, processing choices, and capture lessons from each night.</p>
						<span class="panel-link">Browse posts →</span>
					</div>
				</a>
				<a
					class="split-panel"
					href="/gallery"
					style={`--panel-image: url(${apodImage.src}); --panel-position: 78% 26%;`}
				>
					<div class="panel-inner">
						<p class="chip">Gallery</p>
						<h2>Deep-sky frames</h2>
						<p>Browse stacked nebulae, lunar studies, and wide-field captures.</p>
						<span class="panel-link">View captures →</span>
					</div>
				</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: clamp(1.2rem, 2.6vw, 2.2rem) 0;
		margin-bottom: 1.6rem;
		border-bottom: 1px solid rgba(var(--border), 0.6);
	}
	.hero h1 {
		margin-top: 0.7rem;
		margin-bottom: 0.55rem;
	}
	.hero p {
		max-width: 60ch;
	}
	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 1.2rem;
	}
	.cta {
		padding: 0.55rem 1rem;
		border-radius: 0;
		border: 1px solid rgba(var(--border), 0.8);
		text-decoration: none;
		color: rgb(var(--text));
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.7rem;
	}
	.cta.primary {
		border-color: rgba(var(--accent), 0.9);
		background: rgba(var(--accent), 0.15);
		color: rgb(var(--text));
	}
	.split-panels {
		margin-top: 2rem;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		border-top: 1px solid rgba(var(--border), 0.6);
		border-bottom: 1px solid rgba(var(--border), 0.6);
	}
	.split-panel {
		position: relative;
		min-height: clamp(260px, 38vh, 420px);
		display: flex;
		align-items: flex-end;
		padding: clamp(1.6rem, 4vw, 3rem);
		text-decoration: none;
		color: rgb(var(--text));
		background-image:
			linear-gradient(
				180deg,
				rgba(0, 0, 0, 0.2) 0%,
				rgba(0, 0, 0, 0.55) 65%,
				rgba(0, 0, 0, 0.82) 100%
			),
			var(--panel-image);
		background-size: cover;
		background-position: var(--panel-position, center);
		transition: transform 220ms ease, box-shadow 220ms ease;
	}
	.split-panel + .split-panel {
		border-left: 1px solid rgba(var(--border), 0.6);
	}
	.split-panel:hover {
		transform: translateY(-4px);
		box-shadow: var(--box-shadow);
	}
	.panel-inner {
		max-width: 34ch;
		background: rgba(var(--surface), 0.7);
		border: 1px solid rgba(var(--border), 0.7);
		padding: 1.2rem 1.35rem;
	}
	.panel-inner h2 {
		margin-top: 0.6rem;
		margin-bottom: 0.5rem;
	}
	.panel-link {
		display: inline-block;
		margin-top: 0.9rem;
		font-size: 0.7rem;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: rgb(var(--text));
		border-bottom: 1px solid rgba(var(--border), 0.8);
		padding-bottom: 0.3rem;
	}
	@media (max-width: 960px) {
		.split-panels {
			grid-template-columns: 1fr;
		}
		.split-panel + .split-panel {
			border-left: none;
			border-top: 1px solid rgba(var(--border), 0.6);
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.split-panel {
			transition: none;
		}
		.split-panel:hover {
			transform: none;
			box-shadow: none;
		}
	}
</style>
