---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getBlogImages } from '../lib/blog';

type Props = CollectionEntry<'blog'>['data'] & {
	readingTime: string;
	previousPost?: { slug: string; title: string };
	nextPost?: { slug: string; title: string };
};

const { title, description, pubDate, updatedDate, readingTime, previousPost, nextPost } = Astro.props as Props;
const images = getBlogImages(Astro.props as Props);
const primaryImage = images[0];
const hasMultipleImages = images.length > 1;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={primaryImage} />
		<style>
			main {
				width: min(1020px, calc(100% - 2rem));
			}
			article {
				display: grid;
				gap: 1.3rem;
			}
			.title {
				padding: 1.1rem 1.2rem;
				border: 1px solid rgba(var(--border), 0.9);
				border-radius: var(--radius);
				background: rgba(var(--surface), 0.96);
			}
			.title h1 {
				margin-bottom: 0.35rem;
				font-family: var(--font-heading);
				font-weight: 700;
			}
			.summary {
				margin: 0;
				color: rgba(var(--muted), 0.95);
				font-family: var(--font-body);
				font-weight: 500;
			}
			.date {
				margin: 0;
				color: rgba(var(--muted), 0.95);
				font-size: 0.95rem;
				display: flex;
				flex-wrap: wrap;
				gap: 0.35rem;
			}
			.last-updated-on {
				font-style: italic;
			}
			.reading-time {
				font-weight: 600;
				color: rgb(var(--text));
			}
			.prose {
				padding: 1.2rem 1.3rem;
				border: 1px solid rgba(var(--border), 0.9);
				border-radius: var(--radius);
				background: rgba(var(--surface), 0.92);
			}
			.prose h2,
			.prose h3,
			.prose h4 {
				font-family: var(--font-heading);
				font-weight: 700;
			}
			.media-shell {
				position: relative;
			}
			.hero-carousel {
				display: grid;
				grid-auto-flow: column;
				grid-auto-columns: 100%;
				overflow-x: auto;
				scroll-snap-type: x mandatory;
				scroll-behavior: smooth;
				scrollbar-width: none;
				border: 1px solid rgba(var(--border), 0.9);
				border-radius: var(--radius);
				box-shadow: var(--box-shadow);
				background: rgba(var(--surface), 0.96);
			}
			.hero-carousel::-webkit-scrollbar {
				display: none;
			}
			.hero-slide {
				position: relative;
				scroll-snap-align: start;
				display: grid;
				place-items: center;
			}
			.hero-link {
				display: flex;
				justify-content: center;
				align-items: center;
				padding: 0.75rem;
				color: inherit;
				background: rgba(var(--surface), 0.96);
			}
			.hero-link img {
				display: block;
				width: 100%;
				height: auto;
				max-height: min(78vh, 920px);
				object-fit: contain;
			}
			.hero-actions {
				position: absolute;
				right: 0.8rem;
				bottom: 0.8rem;
				display: flex;
				gap: 0.45rem;
				flex-wrap: wrap;
			}
			.hero-action,
			.carousel-arrow,
			.share-button {
				border: 1px solid rgba(var(--border), 0.9);
				background: rgba(var(--surface-2), 0.92);
				color: rgb(var(--text));
				text-transform: uppercase;
				letter-spacing: 0.12em;
				font-size: 0.68rem;
				text-decoration: none;
				cursor: pointer;
			}
			.hero-action {
				padding: 0.45rem 0.65rem;
			}
			.carousel-arrow {
				position: absolute;
				top: 50%;
				transform: translateY(-50%);
				width: 2.2rem;
				height: 2.2rem;
				display: grid;
				place-items: center;
				border-radius: 999px;
				box-shadow: var(--box-shadow);
				z-index: 1;
			}
			.carousel-arrow:disabled {
				opacity: 0.45;
				cursor: default;
			}
			.carousel-arrow.prev {
				left: 0.75rem;
			}
			.carousel-arrow.next {
				right: 0.75rem;
			}
			.share-button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.5rem 0.7rem;
				margin: 0.55rem 0 0.25rem;
			}
			.share-status {
				min-height: 1em;
				margin: 0 0 0.75rem;
				font-size: 0.78rem;
				color: rgba(var(--muted), 0.95);
			}
			.post-nav {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 0.8rem;
			}
			.post-nav-link {
				display: grid;
				gap: 0.35rem;
				padding: 1rem 1.1rem;
				border: 1px solid rgba(var(--border), 0.9);
				border-radius: var(--radius);
				background: rgba(var(--surface), 0.92);
				color: rgb(var(--text));
				text-decoration: none;
			}
			.post-nav-link:hover {
				border-color: rgba(var(--accent), 0.55);
				box-shadow: var(--box-shadow);
			}
			.post-nav-label {
				font-size: 0.7rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: rgba(var(--muted), 0.85);
			}
			.post-nav-title {
				margin: 0;
				font-family: var(--font-heading);
				font-weight: 700;
				font-size: 1rem;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="title">
					<h1>{title}</h1>
					<button class="share-button" type="button" data-share-post>Share post</button>
					<p class="share-status" data-share-status aria-live="polite"></p>
					<p class="summary">{description}</p>
					<p class="date">
						<FormattedDate date={pubDate} />
						<span class="reading-time"> · {readingTime}</span>
						{
							updatedDate && (
								<span class="last-updated-on">
									· updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</p>
				</div>
				{
					primaryImage && (
						<div class="media-shell">
							{hasMultipleImages && (
								<button class="carousel-arrow prev" type="button" data-carousel-prev aria-label="Previous image">
									←
								</button>
							)}
							<div class="hero-carousel" data-carousel>
								{images.map((image, index) => {
									const fullRes = new URL(image.src, Astro.url).toString();
									return (
										<section class="hero-slide" data-carousel-slide>
											<a class="hero-link" href={fullRes} target="_blank" rel="noreferrer">
												<Image
													width={1020}
													height={images.length > 1 ? 680 : 510}
													src={image}
													alt={index === 0 ? title : `${title} image ${index + 1}`}
												/>
											</a>
											<div class="hero-actions">
												<a class="hero-action" href={fullRes} download>
													Download
												</a>
											</div>
										</section>
									);
								})}
							</div>
							{hasMultipleImages && (
								<button class="carousel-arrow next" type="button" data-carousel-next aria-label="Next image">
									→
								</button>
							)}
						</div>
					)
				}
				<div class="prose">
					<slot />
				</div>
				<nav class="post-nav" aria-label="Post navigation">
					{
						previousPost && (
							<a class="post-nav-link" href={`/blog/${previousPost.slug}/`}>
								<span class="post-nav-label">← Previous</span>
								<p class="post-nav-title">{previousPost.title}</p>
							</a>
						)
					}
					{
						nextPost && (
							<a class="post-nav-link" href={`/blog/${nextPost.slug}/`}>
								<span class="post-nav-label">Next →</span>
								<p class="post-nav-title">{nextPost.title}</p>
							</a>
						)
					}
				</nav>
			</article>
		</main>
		<Footer />
		<script type="module">
			const carousel = document.querySelector('[data-carousel]');
			const prevButton = document.querySelector('[data-carousel-prev]');
			const nextButton = document.querySelector('[data-carousel-next]');
			const shareButton = document.querySelector('[data-share-post]');
			const shareStatus = document.querySelector('[data-share-status]');

			const setShareStatus = (message) => {
				if (shareStatus) {
					shareStatus.textContent = message;
				}
			};

			prevButton?.addEventListener('click', () => {
				if (!(carousel instanceof HTMLElement)) return;
				carousel.scrollBy({ left: -carousel.clientWidth, behavior: 'smooth' });
			});

			nextButton?.addEventListener('click', () => {
				if (!(carousel instanceof HTMLElement)) return;
				carousel.scrollBy({ left: carousel.clientWidth, behavior: 'smooth' });
			});

			shareButton?.addEventListener('click', async () => {
				try {
					await navigator.clipboard.writeText(location.href);
					setShareStatus('Post link copied.');
				} catch {
					setShareStatus('Copy failed. Use the URL in your address bar.');
				}
			});
		</script>
	</body>
</html>
