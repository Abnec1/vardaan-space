---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getBlogImages } from '../lib/blog';

type Props = CollectionEntry<'blog'>['data'] & {
	readingTime: string;
	previousPost?: { slug: string; title: string };
	nextPost?: { slug: string; title: string };
};

const { title, description, pubDate, updatedDate, readingTime, previousPost, nextPost } = Astro.props as Props;
const images = getBlogImages(Astro.props as Props);
const primaryImage = images[0];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={primaryImage} />
		<style>
			main {
				width: min(1020px, calc(100% - 2rem));
			}
			article {
				display: grid;
				gap: 1.3rem;
			}
			.hero-image {
				overflow: hidden;
				border: 1px solid rgba(var(--border), 0.9);
				border-radius: var(--radius);
				box-shadow: var(--box-shadow);
			}
			.hero-image img {
				display: block;
				width: 100%;
			}
			.title {
				padding: 1.1rem 1.2rem;
				border: 1px solid rgba(var(--border), 0.9);
				border-radius: var(--radius);
				background: rgba(var(--surface), 0.96);
			}
			.title h1 {
				margin-bottom: 0.35rem;
				font-family: var(--font-heading);
				font-weight: 700;
			}
			.summary {
				margin: 0;
				color: rgba(var(--muted), 0.95);
				font-family: var(--font-body);
				font-weight: 500;
			}
			.date {
				margin: 0;
				color: rgba(var(--muted), 0.95);
				font-size: 0.95rem;
				display: flex;
				flex-wrap: wrap;
				gap: 0.35rem;
			}
			.last-updated-on {
				font-style: italic;
			}
			.reading-time {
				font-weight: 600;
				color: rgb(var(--text));
			}
			.prose {
				padding: 1.2rem 1.3rem;
				border: 1px solid rgba(var(--border), 0.9);
				border-radius: var(--radius);
				background: rgba(var(--surface), 0.92);
			}
			.prose h2,
			.prose h3,
			.prose h4 {
				font-family: var(--font-heading);
				font-weight: 700;
			}
			.hero-gallery {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 0.8rem;
			}
			.hero-image {
				overflow: hidden;
				border: 1px solid rgba(var(--border), 0.9);
				border-radius: var(--radius);
				box-shadow: var(--box-shadow);
				background: rgba(var(--surface), 0.96);
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
			.post-nav {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 0.8rem;
			}
			.post-nav-link {
				display: grid;
				gap: 0.35rem;
				padding: 1rem 1.1rem;
				border: 1px solid rgba(var(--border), 0.9);
				border-radius: var(--radius);
				background: rgba(var(--surface), 0.92);
				color: rgb(var(--text));
				text-decoration: none;
			}
			.post-nav-link:hover {
				border-color: rgba(var(--accent), 0.55);
				box-shadow: var(--box-shadow);
			}
			.post-nav-label {
				font-size: 0.7rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: rgba(var(--muted), 0.85);
			}
			.post-nav-title {
				margin: 0;
				font-family: var(--font-heading);
				font-weight: 700;
				font-size: 1rem;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="title">
					<h1>{title}</h1>
					<p class="summary">{description}</p>
					<p class="date">
						<FormattedDate date={pubDate} />
						<span class="reading-time"> · {readingTime}</span>
						{
							updatedDate && (
								<span class="last-updated-on">
									· updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</p>
				</div>
				{
					primaryImage && (
						<div class="hero-gallery">
							{images.map((image, index) => (
								<figure class="hero-image">
									<Image
										width={1020}
										height={images.length > 1 ? 680 : 510}
										src={image}
										alt={index === 0 ? title : `${title} image ${index + 1}`}
									/>
								</figure>
							))}
						</div>
					)
				}
				<div class="prose">
					<slot />
				</div>
				<nav class="post-nav" aria-label="Post navigation">
					{
						previousPost && (
							<a class="post-nav-link" href={`/blog/${previousPost.slug}/`}>
								<span class="post-nav-label">← Previous</span>
								<p class="post-nav-title">{previousPost.title}</p>
							</a>
						)
					}
					{
						nextPost && (
							<a class="post-nav-link" href={`/blog/${nextPost.slug}/`}>
								<span class="post-nav-label">Next →</span>
								<p class="post-nav-title">{nextPost.title}</p>
							</a>
						)
					}
				</nav>
			</article>
		</main>
		<Footer />
	</body>
</html>
