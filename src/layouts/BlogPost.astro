---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	readingTime: string;
	previousPost?: { slug: string; title: string };
	nextPost?: { slug: string; title: string };
};

const { title, description, pubDate, updatedDate, heroImage, readingTime, previousPost, nextPost } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: min(1020px, calc(100% - 2rem));
			}
			article {
				display: grid;
				gap: 1.3rem;
			}
			.hero-image {
				overflow: hidden;
				border: 1px solid rgba(var(--border), 0.9);
				border-radius: var(--radius);
				box-shadow: var(--box-shadow);
			}
			.hero-image img {
				display: block;
				width: 100%;
			}
			.title {
				padding: 1.1rem 1.2rem;
				border: 1px solid rgba(var(--border), 0.9);
				border-radius: var(--radius);
				background: rgba(var(--surface), 0.96);
			}
			.title h1 {
				margin-bottom: 0.35rem;
				font-family: var(--font-heading);
				font-weight: 700;
			}
			.summary {
				margin: 0;
				color: rgba(var(--muted), 0.95);
				font-family: var(--font-body);
				font-weight: 500;
			}
			.date {
				margin: 0;
				color: rgba(var(--muted), 0.95);
				font-size: 0.95rem;
				display: flex;
				flex-wrap: wrap;
				gap: 0.35rem;
			}
			.last-updated-on {
				font-style: italic;
			}
			.reading-time {
				font-weight: 600;
				color: rgb(var(--text));
			}
			.prose {
				padding: 1.2rem 1.3rem;
				border: 1px solid rgba(var(--border), 0.9);
				border-radius: var(--radius);
				background: rgba(var(--surface), 0.92);
			}
			.prose h2,
			.prose h3,
			.prose h4 {
				font-family: var(--font-heading);
				font-weight: 700;
			}
			.comments {
				padding: 1.2rem 1.3rem;
			}
			.comments-head h2 {
				margin-bottom: 0.4rem;
			}
			.muted {
				margin: 0.3rem 0 0;
				color: rgba(var(--muted), 0.9);
				font-size: 0.9rem;
			}
			.comment-list {
				margin-top: 1.2rem;
				display: grid;
				gap: 0.8rem;
			}
			.comment-card {
				border: 1px solid rgba(var(--border), 0.8);
				border-radius: 0;
				padding: 0.8rem 0.9rem;
				background: rgba(var(--surface-2), 0.75);
			}
			.comment-head {
				display: flex;
				justify-content: space-between;
				gap: 0.6rem;
				align-items: baseline;
			}
			.comment-name {
				margin: 0;
				font-size: 0.85rem;
				text-transform: uppercase;
				letter-spacing: 0.12em;
			}
			.comment-date {
				margin: 0;
				font-size: 0.75rem;
				color: rgba(var(--muted), 0.85);
			}
			.comment-body {
				margin: 0.6rem 0 0;
			}
			.empty {
				margin: 0;
				color: rgba(var(--muted), 0.9);
			}
			.comment-form {
				margin-top: 1.3rem;
				display: grid;
				gap: 0.9rem;
			}
			label {
				display: grid;
				gap: 0.4rem;
				font-size: 0.75rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: rgba(var(--muted), 0.85);
			}
			input,
			textarea {
				background: rgba(var(--surface-2), 0.85);
				border: 1px solid rgba(var(--border), 0.8);
				color: rgb(var(--text));
				padding: 0.6rem 0.7rem;
				border-radius: 0;
				font-size: 0.95rem;
			}
			button {
				justify-self: start;
				padding: 0.6rem 1rem;
				border-radius: 0;
				border: 1px solid rgba(var(--accent), 0.9);
				background: rgba(var(--accent), 0.2);
				color: rgb(var(--text));
				text-transform: uppercase;
				letter-spacing: 0.12em;
				font-size: 0.7rem;
				cursor: pointer;
			}
			.post-nav {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 0.8rem;
			}
			.post-nav-link {
				display: grid;
				gap: 0.35rem;
				padding: 1rem 1.1rem;
				border: 1px solid rgba(var(--border), 0.9);
				border-radius: var(--radius);
				background: rgba(var(--surface), 0.92);
				color: rgb(var(--text));
				text-decoration: none;
			}
			.post-nav-link:hover {
				border-color: rgba(var(--accent), 0.55);
				box-shadow: var(--box-shadow);
			}
			.post-nav-label {
				font-size: 0.7rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: rgba(var(--muted), 0.85);
			}
			.post-nav-title {
				margin: 0;
				font-family: var(--font-heading);
				font-weight: 700;
				font-size: 1rem;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="title">
					<h1>{title}</h1>
					<p class="summary">{description}</p>
					<p class="date">
						<FormattedDate date={pubDate} />
						<span class="reading-time"> · {readingTime}</span>
						{
							updatedDate && (
								<span class="last-updated-on">
									· updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</p>
				</div>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<slot />
				</div>
				<section class="comments glass-card">
					<div class="comments-head">
						<p class="chip">Comments</p>
						<h2>Discussion</h2>
						<p class="muted">Comments are stored locally in your browser for this post.</p>
					</div>
					<div class="comment-list" data-comment-list>
						<p class="empty">No comments yet. Be the first to log a response.</p>
					</div>
					<form class="comment-form" data-comment-form>
						<label>
							Callsign
							<input name="name" type="text" autocomplete="name" required />
						</label>
						<label>
							Email (optional)
							<input name="email" type="email" autocomplete="email" />
						</label>
						<label>
							Message
							<textarea name="message" rows="4" required></textarea>
						</label>
						<button type="submit">Send comment</button>
					</form>
				</section>
				<nav class="post-nav" aria-label="Post navigation">
					{
						previousPost && (
							<a class="post-nav-link" href={`/blog/${previousPost.slug}/`}>
								<span class="post-nav-label">← Previous</span>
								<p class="post-nav-title">{previousPost.title}</p>
							</a>
						)
					}
					{
						nextPost && (
							<a class="post-nav-link" href={`/blog/${nextPost.slug}/`}>
								<span class="post-nav-label">Next →</span>
								<p class="post-nav-title">{nextPost.title}</p>
							</a>
						)
					}
				</nav>
			</article>
		</main>
		<Footer />
		<script type="module">
			const storageKey = `comments:${location.pathname}`;
			const list = document.querySelector('[data-comment-list]');
			const form = document.querySelector('[data-comment-form]');

			const render = (comments) => {
				if (!list) return;
				list.innerHTML = '';
				if (!comments.length) {
					const empty = document.createElement('p');
					empty.className = 'empty';
					empty.textContent = 'No comments yet. Be the first to log a response.';
					list.append(empty);
					return;
				}
				comments.forEach((comment) => {
					const card = document.createElement('div');
					card.className = 'comment-card';

					const head = document.createElement('div');
					head.className = 'comment-head';

					const name = document.createElement('p');
					name.className = 'comment-name';
					name.textContent = comment.name;

					const date = document.createElement('p');
					date.className = 'comment-date';
					date.textContent = new Date(comment.timestamp).toLocaleDateString('en-US', {
						month: 'short',
						day: 'numeric',
						year: 'numeric',
					});

					const body = document.createElement('p');
					body.className = 'comment-body';
					body.textContent = comment.message;

					head.append(name, date);
					card.append(head, body);
					list.append(card);
				});
			};

			const stored = JSON.parse(localStorage.getItem(storageKey) || '[]');
			render(stored);

			form?.addEventListener('submit', (event) => {
				event.preventDefault();
				const formData = new FormData(form);
				const name = formData.get('name')?.toString().trim();
				const message = formData.get('message')?.toString().trim();

				if (!name || !message) return;

				const next = [
					...stored,
					{
						name,
						message,
						timestamp: Date.now(),
					},
				];
				localStorage.setItem(storageKey, JSON.stringify(next));
				stored.splice(0, stored.length, ...next);
				form.reset();
				render(next);
			});
		</script>
	</body>
</html>
